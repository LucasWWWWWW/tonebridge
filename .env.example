# ---- LLM（OpenAI 兼容接口，三选一填好）----
# DeepSeek（默认推荐）
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat
# Gemini / OpenAI 也兼容，改这三个即可

# ---- 可选：限流（配了 Upstash Redis 才启用，不配则不限流）----
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# DEMO_DAILY_LIMIT_PER_IP=30
# DEMO_GLOBAL_DAILY_LIMIT=2000
